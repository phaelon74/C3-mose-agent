[Unit]
Description=Mose Agent - Custom AI Assistant
After=network-online.target worker-agent.service signal-cli-daemon.service
Wants=network-online.target signal-cli-daemon.service
Requires=worker-agent.service

[Service]
Type=simple
User=mose
WorkingDirectory=/home/mose/mose-agent
EnvironmentFile=-/home/mose/mose-agent/.env
ExecStart=/home/mose/mose-agent/.venv/bin/python -m mose
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
