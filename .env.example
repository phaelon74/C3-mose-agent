# Cloud3 SRE Credentials
# Copy to .env and fill in values. chmod 600 .env
#
# Docker Compose (Linux): GID of the host "docker" group so the agent image
# matches the socket. Set with: echo "DOCKER_GID=$(getent group docker | cut -d: -f3)" >> .env
# See INSTALL.md section A.4.
#DOCKER_GID=

# Signal (signal-cli daemon, requires signal-cli 0.14.0+)
SIGNAL_PHONE=

# Mose Agent — LLM (OpenAI-compatible API; see README / INSTALL.md)
LLM_ENDPOINT=
LLM_MODEL=
LLM_MAX_TOKENS=
LLM_TEMPERATURE=
LLM_OMIT_TEMPERATURE=
LLM_CONTEXT_WINDOW=
LLM_API_KEY=
LLM_PROVIDER=

# Media Stack
RADARR_API_KEY=
SONARR_API_KEY=
PLEX_TOKEN=
NZBGET_PASSWORD=

# Infrastructure
OPNSENSE_API_KEY=
OPNSENSE_API_SECRET=
PROXMOX_API_TOKEN_ID=
PROXMOX_API_TOKEN_SECRET=
TRUENAS_API_KEY=

# Docker Apps
PULSARR_API_KEY=
HUNTARR_API_KEY=
HOMARR_API_KEY=

# DrivePool (Windows - pypsrp)
DRIVEPOOL_HOST=
DRIVEPOOL_USER=
DRIVEPOOL_PASSWORD=
