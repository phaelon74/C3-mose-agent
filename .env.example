# Cloud3 SRE Credentials
# Copy to .env and fill in values. chmod 600 .env
#
# Docker Compose (Linux): GID of the host "docker" group so the agent image
# matches the socket. Set with: echo "DOCKER_GID=$(getent group docker | cut -d: -f3)" >> .env
# See INSTALL.md section A.4.
#DOCKER_GID=

# Signal (signal-cli daemon, requires signal-cli 0.14.0+). See INSTALL.md section E.
# SIGNAL_PHONE is the linked device account (signal-cli -a). Group ids are destinations.
SIGNAL_PHONE=
SIGNAL_ENGAGEMENT_GROUP_ID=
SIGNAL_ADMIN_GROUP_ID=

# Mose Agent — LLM (OpenAI-compatible API; see README / INSTALL.md)
LLM_ENDPOINT=
LLM_MODEL=
LLM_MAX_TOKENS=
LLM_TEMPERATURE=
LLM_OMIT_TEMPERATURE=
LLM_CONTEXT_WINDOW=
LLM_API_KEY=
LLM_PROVIDER=

# Plex MCP sidecars (docker compose: plex-ops-admin, plex-stack-automation).
# Consumed only by those MCP containers — not by mose-agent. Each service may
# use its own host:port on your LAN (e.g. 10.4.251.x). See INSTALL.md section D.
#PLEX_URL=http://10.4.251.10:32400
#PLEX_TOKEN=
#SONARR_URL=http://10.4.251.11:8989
#SONARR_API_KEY=
#RADARR_URL=http://10.4.251.12:7878
#RADARR_API_KEY=
# Optional (niavasha Trakt tools):
#TRAKT_CLIENT_ID=
#TRAKT_CLIENT_SECRET=

NZBGET_PASSWORD=

# Infrastructure
OPNSENSE_API_KEY=
OPNSENSE_API_SECRET=
PROXMOX_API_TOKEN_ID=
PROXMOX_API_TOKEN_SECRET=
TRUENAS_API_KEY=

# Docker Apps
PULSARR_API_KEY=
HUNTARR_API_KEY=
HOMARR_API_KEY=

# DrivePool (Windows - pypsrp)
DRIVEPOOL_HOST=
DRIVEPOOL_USER=
DRIVEPOOL_PASSWORD=
